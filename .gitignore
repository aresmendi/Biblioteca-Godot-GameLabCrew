# =========================
# Godot .gitignore
# =========================

# Import e cache generate automaticamente da Godot
.import/
.godot/

# Export presets locali
export.cfg
export_presets.cfg

# File temporanei
*.tmp
*.temp
*.log
*~
*.bak

# File di sistema
.DS_Store
Thumbs.db

# Cache / file generati da Godot
*.gdc
*.import

# Build esportate
build/
*.exe
*.pck
*.apk
*.aab
*.ipa
*.x86_64
*.zip

# Config locali editor
.editor_settings-*.tres

# Mono / C#
.mono/
data_*/
*.csproj
*.sln
*.user
*.dotsettings

# VSCode
.vscode/

# JetBrains / Rider
.idea/

# =========================
# NON ignorare
# =========================
# project.godot
# *.tscn
# *.tres
# *.gd
# assets/